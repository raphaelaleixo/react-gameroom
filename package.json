{
  "name": "react-gameroom",
  "version": "0.5.0",
  "description": "A reusable multiplayer lobby system for casual/local multiplayer games",
  "author": "Raphael Avellar",
  "license": "MIT",
  "keywords": ["react", "multiplayer", "lobby", "gameroom", "game", "qrcode", "room", "player"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raphaelaleixo/react-gameroom.git"
  },
  "homepage": "https://github.com/raphaelaleixo/react-gameroom#readme",
  "bugs": {
    "url": "https://github.com/raphaelaleixo/react-gameroom/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "qrcode.react": "^4.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
